# SOS Angola Backend - Variáveis de ambiente
# Copie para .env e ajuste os valores

# Aplicação
APP_NAME=SOS Angola API
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Servidor
HOST=0.0.0.0
PORT=8000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua_senha
DB_NAME=sos_angola
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# JWT
SECRET_KEY=altere-esta-chave-secreta-em-producao
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Job de medicação ignorada (corre a cada 15 min; define uma chave para ativar)
CRON_SECRET=

# QuePasa (WhatsApp): URL do serviço e token. Para notificar o cuidador por WhatsApp.
# Instale QuePasa (git clone ... quepasa, depois docker compose up -d em quepasa/docker), ligue o WhatsApp na UI e copie o token.
QUEPASA_BASE_URL=http://localhost:31000
QUEPASA_TOKEN=

# Upload (fotos/vídeos ocorrências)
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,mp4,webm

# CORS (origens permitidas separadas por vírgula)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Timezone
TIMEZONE=Africa/Luanda
